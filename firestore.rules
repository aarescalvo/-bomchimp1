rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens don't have roles, look them up in /users
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }
    function isAdmin() { return hasRole('admin'); }
    function isOperator() { return hasRole('operator') || isAdmin(); }
    function isFirefighter() { return hasRole('firefighter') || isOperator(); }

    // Helpers for common fields
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Validation Helpers
    function isValidUser(data) {
      return data.uid == request.auth.uid 
             && data.displayName is string && data.displayName.size() <= 100
             && data.email is string && data.email.size() <= 100
             && data.role in ['admin', 'operator', 'firefighter'];
    }

    function isValidInventory(data) {
      return data.name is string && data.name.size() <= 100
             && data.quantity is number && data.quantity >= 0
             && data.unit is string && data.unit.size() <= 20;
    }

    function isValidIncident(data) {
      return data.timestamp is timestamp
             && data.type is string
             && data.status in ['open', 'dispatched', 'closed']
             && data.severity in ['low', 'medium', 'high', 'critical'];
    }

    function isValidShift(data) {
      return data.userId == request.auth.uid
             && data.startTime is timestamp
             && data.status in ['active', 'completed'];
    }

    function isValidRental(data) {
      return data.customerName is string && data.customerName.size() <= 100
             && data.startTime is timestamp && data.endTime is timestamp
             && data.price is number && data.price >= 0;
    }

    // 1. Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isOperator();
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastActive'])) 
        || isAdmin()
      );
    }

    // 2. Inventory
    match /inventory/{itemId} {
      allow read: if isFirefighter();
      allow create, update: if isOperator() && isValidInventory(incoming());
      allow delete: if isAdmin();
    }

    // 3. Incidents
    match /incidents/{incidentId} {
      allow read: if isFirefighter();
      allow create: if isOperator() && isValidIncident(incoming());
      allow update: if isOperator() && (
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'description', 'location'])
      );
      allow delete: if isAdmin();
    }

    // 4. Shifts
    match /shifts/{shiftId} {
      allow read: if isFirefighter() && (isOwner(existing().userId) || isOperator());
      allow create: if isFirefighter() && isValidShift(incoming());
      allow update: if isFirefighter() && isOwner(existing().userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['endTime', 'status'])
      );
      allow delete: if isAdmin();
    }

    // 5. Agenda
    match /agenda/{taskId} {
      allow read: if isFirefighter();
      allow create: if isOperator();
      allow update: if isFirefighter() && (
        (isFirefighter() && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        || isOperator()
      );
      allow delete: if isOperator();
    }

    // 6. Rentals
    match /rentals/{rentalId} {
      allow read: if isOperator();
      allow create, update: if isOperator() && isValidRental(incoming());
      allow delete: if isAdmin();
    }

    // 7. Finances
    match /finances/{transactionId} {
      allow read: if isOperator();
      allow create: if isOperator();
      allow update: if isAdmin();
      allow delete: if false; // Finances should be immutable
    }

    // 8. Services
    match /services/{serviceId} {
      allow read: if isFirefighter();
      allow create, update: if isOperator();
      allow delete: if isAdmin();
    }
  }
}
